rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: users/{userId}/history
    // Document ID: {historyId}
    // Fields:
    //   - id: string (required, must match document ID)
    //   - userId: string (required, must match {userId})
    //   - timestamp: number (required, positive)
    //   - data: string (required, JSON stringified PrescriptionData)
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }
    
    function hasOnlyAllowedFields(fields) {
      return request.resource.data.keys().hasOnly(fields);
    }
    
    // Domain Validator
    function isValidHistoryItem(userId, historyId) {
      return hasOnlyAllowedFields(['id', 'userId', 'timestamp', 'data']) &&
             request.resource.data.id is string &&
             request.resource.data.id == historyId &&
             request.resource.data.userId is string &&
             request.resource.data.userId == userId &&
             request.resource.data.timestamp is number &&
             request.resource.data.timestamp > 0 &&
             request.resource.data.data is string &&
             request.resource.data.data.size() < 1000000; // 1MB limit check
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /users/{userId}/history/{historyId} {
      allow read: if isOwner(userId);
      allow create: if isOwner(userId) && isValidHistoryItem(userId, historyId);
      allow update: if isOwner(userId) && isValidHistoryItem(userId, historyId);
      allow delete: if isOwner(userId);
    }
    
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
