# Copy this file to .env.local and fill in your values.
# .env.local is gitignored — never commit real secrets.

# ─── Dev mode ────────────────────────────────────────────────────────────────
# Set to "true" to bypass Google sign-in and call Gemini directly from the
# client. NEVER set this in production — it bypasses auth and exposes the key.
VITE_DEV_MODE=false

# Your Gemini API key — only used when VITE_DEV_MODE=true.
# Get one free at https://aistudio.google.com/app/apikey
# In production the key lives as a Firebase secret (firebase functions:secrets:set GEMINI_API_KEY)
# and is NEVER read by the Vite frontend.
VITE_GEMINI_API_KEY=
