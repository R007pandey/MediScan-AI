# Copy this file to .env.local and fill in your values.
# .env.local is gitignored — never commit real secrets.

# The Gemini API key is ONLY needed for the Cloud Function (functions/.env).
# It is NOT read by the Vite frontend. If you see it referenced in vite.config.ts
# from an older version, that was a security issue — it has been removed.
#
# For local development with the Firebase emulator, create functions/.env:
#   GEMINI_API_KEY=your-key-here
#
# For production deploy, set it as a Firebase secret:
#   firebase functions:secrets:set GEMINI_API_KEY
